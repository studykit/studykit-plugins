{
  "description": "guard hooks. Logic lives in `scripts/guard_hook.py`; see `dev/AGENTS.md` for the design.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/guard_hook.py\" user-prompt",
            "timeout": 120,
            "description": "Log the user turn and update approval-gate state."
          }
        ]
      }
    ],
    "UserPromptExpansion": [
      {
        "matcher": "turn",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/guard_hook.py\" toggle",
            "timeout": 5,
            "description": "Toggle the session's evidence judge."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/guard_hook.py\" gate",
            "timeout": 10,
            "description": "Gate file-mutating tools on the approval state."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/guard_hook.py\" stop",
            "timeout": 120,
            "description": "Log the assistant turn and run the evidence judge when armed."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/guard_hook.py\" session-start",
            "timeout": 5,
            "description": "Sweep guard state and logs past the retention window."
          }
        ]
      }
    ]
  }
}
