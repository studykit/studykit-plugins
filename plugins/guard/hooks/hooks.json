{
  "description": "guard hooks. Logic lives in `scripts/guard_hook.py`; see `dev/design.md` for the design.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/guard_hook.py\" user-prompt",
            "timeout": 120,
            "description": "Log the user turn and update approval-gate state (gate only)."
          }
        ]
      }
    ],
    "UserPromptExpansion": [
      {
        "matcher": "^(guard:)?turn$",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/guard_hook.py\" toggle",
            "timeout": 5,
            "description": "Toggle the approval gate for the session."
          }
        ]
      },
      {
        "matcher": "^(guard:)?audit-mode$",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/guard_hook.py\" set-mode",
            "timeout": 5,
            "description": "Set the session's evidence-judge mode (manual|subagent|headless)."
          }
        ]
      },
      {
        "matcher": "^(guard:)?audit$",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/guard_hook.py\" verify",
            "timeout": 5,
            "description": "On demand, dispatch the guardian to audit the last completed turn."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/guard_hook.py\" gate",
            "timeout": 10,
            "description": "Gate file-mutating tools on the approval state."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/guard_hook.py\" plan-approved",
            "timeout": 60,
            "description": "On plan approval, arm the approval gate when the plan defers no in-scope work."
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/guard_hook.py\" gate-approved",
            "timeout": 10,
            "description": "In gate_mode ask, arm the approval gate after the user approves an edit's permission prompt."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/guard_hook.py\" stop",
            "timeout": 120,
            "description": "Log the assistant turn and run the evidence judge when armed."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/guard_hook.py\" session-start",
            "timeout": 5,
            "description": "Sweep guard state and logs past the retention window."
          }
        ]
      }
    ]
  }
}
