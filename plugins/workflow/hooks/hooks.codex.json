{
  "description": "Workflow hooks for Codex. SessionStart injects provider-backed workflow authoring policy and cache-base context only when workflow.config.yml exists in the active project. UserPromptSubmit and Stop pre-read mentioned GitHub issue references through cache-aware provider reads and inject issue-cache-base-relative paths as additionalContext.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "WORKFLOW_HOOK_RUNTIME=codex python3 \"${PLUGIN_ROOT}/scripts/workflow_hook.py\" pre-write",
            "timeout": 5,
            "statusMessage": "Checking workflow authoring ledger",
            "description": "Block local workflow projection writes until required authoring files were read"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "WORKFLOW_HOOK_RUNTIME=codex python3 \"${PLUGIN_ROOT}/scripts/workflow_hook.py\" post-read",
            "timeout": 5,
            "statusMessage": "Recording workflow authoring read",
            "description": "Record reads of workflow authoring files in the session ledger"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "WORKFLOW_HOOK_RUNTIME=codex python3 \"${PLUGIN_ROOT}/scripts/workflow_hook.py\" session-start",
            "timeout": 5,
            "statusMessage": "Loading workflow authoring policy",
            "description": "Inject workflow authoring resolver policy for configured workflow projects"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "WORKFLOW_HOOK_RUNTIME=codex python3 \"${PLUGIN_ROOT}/scripts/workflow_hook.py\" user-prompt",
            "timeout": 10,
            "statusMessage": "Caching workflow issue references",
            "description": "Cache mentioned GitHub issue references and inject issue-cache-base-relative paths as additionalContext"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "WORKFLOW_HOOK_RUNTIME=codex python3 \"${PLUGIN_ROOT}/scripts/workflow_hook.py\" stop",
            "timeout": 10,
            "statusMessage": "Finalizing workflow issue cache",
            "description": "Ensure session-mentioned GitHub issues have cache projections; inject only newly announced relative paths"
          }
        ]
      }
    ]
  }
}
