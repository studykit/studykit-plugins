#!/usr/bin/env bash
# Workflow script launcher. Uses Claude's persisted environment as-is, sources
# Codex's hook-generated environment, or falls back to local terminal defaults.

set -euo pipefail

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
PLUGIN_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd -P)"

if [ "$#" -lt 1 ]; then
  echo "usage: workflow <script.py|command> [args...]" >&2
  exit 2
fi

exec_workflow_command() {
  local command="$1"
  shift

  local candidate
  if [[ "$command" != */* ]]; then
    candidate="$SCRIPT_DIR/$command"
  else
    candidate="$command"
  fi

  if [[ "$candidate" == *.py && -f "$candidate" ]]; then
    exec uv run --script "$candidate" "$@"
  fi

  exec "$candidate" "$@"
}

resolve_project_dir() {
  if [ -n "${WORKFLOW_PROJECT_DIR:-}" ]; then
    printf '%s\n' "$WORKFLOW_PROJECT_DIR"
    return 0
  fi
  if git_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    printf '%s\n' "$git_root"
    return 0
  fi
  pwd -P
}

source_codex_env_file() {
  local project_dir
  project_dir="$(resolve_project_dir)"

  local env_file
  env_file="$(python3 "$SCRIPT_DIR/workflow_env.py" codex-env-path --project "$project_dir" --session "$CODEX_THREAD_ID")"
  if [ -f "$env_file" ]; then
    # shellcheck disable=SC1090
    . "$env_file"
  fi
}

apply_terminal_environment() {
  export WORKFLOW="$SCRIPT_DIR/workflow"
  export WORKFLOW_PLUGIN_ROOT="$PLUGIN_ROOT"
  export WORKFLOW_PROJECT_DIR="${WORKFLOW_PROJECT_DIR:-$(resolve_project_dir)}"
}

COMMAND="$1"
shift

if [ -n "${CLAUDE_CODE_SESSION_ID:-}" ]; then
  exec_workflow_command "$COMMAND" "$@"
fi
if [ -n "${CODEX_THREAD_ID:-}" ]; then
  source_codex_env_file
  exec_workflow_command "$COMMAND" "$@"
fi

apply_terminal_environment
exec_workflow_command "$COMMAND" "$@"
