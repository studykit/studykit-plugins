#!/usr/bin/env bash
# Runtime-aware workflow script launcher.

set -euo pipefail

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
PLUGIN_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd -P)"

resolve_project_dir() {
  if [ -n "${WORKFLOW_PROJECT_DIR:-}" ]; then
    printf '%s\n' "$WORKFLOW_PROJECT_DIR"
    return 0
  fi
  if git_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    printf '%s\n' "$git_root"
    return 0
  fi
  pwd -P
}

PROJECT_DIR="$(resolve_project_dir)"

if [ -n "${CODEX_THREAD_ID:-}" ] && [ -n "${CLAUDE_CODE_SESSION_ID:-}" ]; then
  echo "workflow: ambiguous shell runtime: both CODEX_THREAD_ID and CLAUDE_CODE_SESSION_ID are set" >&2
  exit 2
fi

if [ -n "${CODEX_THREAD_ID:-}" ]; then
  ENV_FILE="$(python3 "$SCRIPT_DIR/workflow_env.py" codex-env-path --project "$PROJECT_DIR" --session "$CODEX_THREAD_ID")"
  if [ -f "$ENV_FILE" ]; then
    # shellcheck disable=SC1090
    . "$ENV_FILE"
  else
    export WORKFLOW_SESSION_ID="${WORKFLOW_SESSION_ID:-$CODEX_THREAD_ID}"
  fi
elif [ -n "${CLAUDE_CODE_SESSION_ID:-}" ]; then
  export WORKFLOW_SESSION_ID="${WORKFLOW_SESSION_ID:-$CLAUDE_CODE_SESSION_ID}"
fi

export WORKFLOW_PLUGIN_ROOT="${WORKFLOW_PLUGIN_ROOT:-$PLUGIN_ROOT}"
export WORKFLOW_PROJECT_DIR="${WORKFLOW_PROJECT_DIR:-$PROJECT_DIR}"

if [ "$#" -lt 1 ]; then
  echo "usage: workflow <script.py|command> [args...]" >&2
  exit 2
fi

COMMAND="$1"
shift

if [[ "$COMMAND" != */* ]]; then
  CANDIDATE="$SCRIPT_DIR/$COMMAND"
else
  CANDIDATE="$COMMAND"
fi

if [[ "$CANDIDATE" == *.py && -f "$CANDIDATE" ]]; then
  exec python3 "$CANDIDATE" "$@"
fi

exec "$CANDIDATE" "$@"
