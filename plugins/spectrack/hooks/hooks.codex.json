{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --script \"${PLUGIN_ROOT}/hooks/scripts/hook_codex.py\"",
            "timeout": 5,
            "statusMessage": "Loading workflow authoring policy"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --script \"${PLUGIN_ROOT}/hooks/scripts/hook_codex.py\"",
            "timeout": 5,
            "statusMessage": "Loading workflow subagent policy"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --script \"${PLUGIN_ROOT}/hooks/scripts/hook_codex.py\"",
            "timeout": 10,
            "statusMessage": "Caching workflow issue references"
          }
        ]
      }
    ]
  }
}
