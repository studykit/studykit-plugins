#!/usr/bin/env bash
# Resolve the workflow project directory and optionally prepare a subpath.
#
# Usage:
#   workflow project-dir                  # print the resolved project root
#   workflow project-dir <relative-path>  # join with the resolved root,
#                                         # mkdir -p the directory part
#                                         # (the path itself when it ends
#                                         # with `/`, otherwise its parent),
#                                         # then print the joined absolute
#                                         # path
#
# Resolution order:
#   1. $SPECTRACK_PROJECT_DIR when set.
#   2. Parent of `git rev-parse --git-common-dir` so callers running inside
#      a linked worktree anchor on the main repo root, not the worktree.
#   3. Current working directory.

set -euo pipefail

resolve_root() {
  if [ -n "${SPECTRACK_PROJECT_DIR:-}" ]; then
    (cd "$SPECTRACK_PROJECT_DIR" && pwd -P)
    return 0
  fi

  if git_common_dir="$(git rev-parse --git-common-dir 2>/dev/null)"; then
    abs_common_dir="$(cd "$git_common_dir" && pwd -P)"
    dirname "$abs_common_dir"
    return 0
  fi

  pwd -P
}

ROOT="$(resolve_root)"

if [ "$#" -eq 0 ]; then
  printf '%s\n' "$ROOT"
  exit 0
fi

if [ "$#" -gt 1 ]; then
  echo "usage: workflow project-dir [<relative-path>]" >&2
  exit 2
fi

REL="$1"
case "$REL" in
  /*)
    echo "project-dir: relative path must not start with /" >&2
    exit 2
    ;;
esac

JOINED="$ROOT/$REL"
case "$REL" in
  */) mkdir -p "$JOINED" ;;
  *)  mkdir -p "$(dirname "$JOINED")" ;;
esac
printf '%s\n' "$JOINED"
